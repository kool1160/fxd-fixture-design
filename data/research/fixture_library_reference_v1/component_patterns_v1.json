    {
      "schema_version": "fxd-fixture-library-item-v1",
      "item_id": "component-pattern-007-clamp-bracket",
      "name": "Clamp bracket with reaction evidence",
      "record_type": "component_application",
      "category": "fxd_standard_parametric_primitive",
      "authority_level": "fxd_parametric_component",
      "revision": "1",
      "units": "mm",
      "privacy_classification": "public",
      "summary": "A clamp bracket binds the commercial clamp mounting interface to the fixture structure and records the product contact and reaction path separately.",
      "source_ids": [
        "destaco-welding-applications"
      ],
      "applicability": [
        "manual, pneumatic, or hydraulic clamp mounting"
