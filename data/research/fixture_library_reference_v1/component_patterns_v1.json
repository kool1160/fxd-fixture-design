      "name": "Replaceable hard stop",
      "record_type": "component_application",
      "category": "fxd_standard_parametric_primitive",
      "authority_level": "fxd_parametric_component",
      "revision": "1",
      "units": "mm",
      "privacy_classification": "public",
      "summary": "Apply a stop against a verified product feature with clear approach, seating, unload, adjustment, and wear-replacement behavior.",
      "source_ids": [
        "fixtureworks-components"
      ],
      "applicability": [
        "tertiary location",
        "end location",
        "loading stop"
      ],
      "limitations": [
        "a stop is not automatically a clamp or support"
      ],
      "engineering_details": {
        "required_inputs": [
          "contact feature",
          "stop direction",
          "replacement interface"
        ],
        "reject_when": [
