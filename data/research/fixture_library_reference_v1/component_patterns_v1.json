  "records": [
    {
      "schema_version": "fxd-fixture-library-item-v1",
      "item_id": "component-pattern-001-support-pad",
      "name": "Product-bound support pad",
      "record_type": "component_application",
      "category": "fxd_standard_parametric_primitive",
      "authority_level": "fxd_parametric_component",
      "revision": "1",
      "units": "mm",
      "privacy_classification": "public",
      "summary": "Apply a discrete support pad at a verified stable product region and assign its datum, auxiliary, or clamp-reaction role explicitly.",
      "source_ids": [
        "fixtureworks-components",
        "jergens-fixturing-components"
      ],
      "applicability": [
        "sheet",
        "plate",
        "tube",
        "fabricated assemblies"
      ],
      "limitations": [
        "contact suitability and height require project geometry"
      ],
      "engineering_details": {
        "required_inputs": [
          "product reference",
          "support direction",
          "contact allowance",
          "wear intent"
        ],
        "reject_when": [
          "support is under an unstable or forbidden region",
          "clamp load has no reaction path"
        ]
      }
    },
    {
      "schema_version": "fxd-fixture-library-item-v1",
      "item_id": "component-pattern-002-round-locator-pin",
      "name": "Round locator pin",
      "record_type": "component_application",
      "category": "fxd_standard_parametric_primitive",
      "authority_level": "fxd_parametric_component",
      "revision": "1",
      "units": "mm",
      "privacy_classification": "public",
      "summary": "Use a round pin only where verified hole geometry, fit intent, insertion direction, wear, and controlled degrees of freedom are explicit.",
      "source_ids": [
        "carr-lane-fixture-design-principles",
        "jergens-fixturing-components"
      ],
      "applicability": [
        "verified locating holes"
      ],
      "limitations": [
        "diameter, fit, bushing, and tolerance are project-specific"
      ],
      "engineering_details": {
        "required_inputs": [
          "hole identity",
          "nominal axis",
          "fit class intent",
          "insertion clearance"
        ],
        "reject_when": [
          "hole authority is provisional",
          "two round pins redundantly constrain variation"
        ]
      }
    },
    {
      "schema_version": "fxd-fixture-library-item-v1",
      "item_id": "component-pattern-003-relieved-locator",
      "name": "Relieved or directional locator",
      "record_type": "component_application",
      "category": "fxd_standard_parametric_primitive",
      "authority_level": "fxd_parametric_component",
      "revision": "1",
      "units": "mm",
      "privacy_classification": "public",
      "summary": "Use a relieved contact to control the intended direction while allowing variation or thermal movement in the orthogonal direction.",
      "source_ids": [
        "carr-lane-fixture-design-principles"
      ],
      "applicability": [
        "secondary location with known variation direction"
      ],
      "limitations": [
        "relief orientation and contact width require deterministic evidence"
      ],
      "engineering_details": {
        "required_inputs": [
          "controlled direction",
          "floating direction",
          "contact normal"
        ],
        "reject_when": [
          "relief direction contradicts datum intent"
        ]
      }
    },
    {
      "schema_version": "fxd-fixture-library-item-v1",
