      "engineering_details": {
        "required_inputs": [
          "connected parent identities",
          "access corridors",
          "manufacturing method"
        ],
        "reject_when": [
          "gusset is disconnected or decorative",
          "gusset obstructs required access"
        ]
      }
    },
    {
