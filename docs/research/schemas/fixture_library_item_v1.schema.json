{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fxd.invalid/research/fixture_library_item_v1.schema.json",
  "title": "FXD fixture library item v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "item_id",
    "name",
    "record_type",
    "category",
    "authority_level",
    "supplier_or_author",
    "model_or_internal_number",
    "revision",
    "units",
    "source_file",
    "source_ids",
    "provenance",
    "privacy_classification",
    "storage_policy",
    "edit_authority",
    "local_coordinate_system",
    "preview_representation",
    "feature_definition",
    "mounting_interfaces",
    "functional_interfaces",
    "contact_points",
    "movement_states",
    "open_closed_states",
    "keep_out_envelopes",
    "maintenance_envelopes",
    "material_manufacturing_intent",
    "bom_participation",
    "export_participation",
    "validation_participation",
    "configurable_variants",
    "replacement_compatibility",
    "missing_link_behavior",
    "downstream_dependencies",
    "summary",
    "applicability",
    "limitations",
    "engineering_details",
    "tags"
  ],
  "properties": {
    "schema_version": {
      "const": "fxd-fixture-library-item-v1"
    },
    "item_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "record_type": {
      "enum": [
        "engineering_principle",
        "fixture_pattern",
        "component_application",
        "failure_mode",
        "library_component"
      ]
    },
    "category": {
      "enum": [
        "fxd_standard_parametric_primitive",
        "shop_standard_pack",
        "private_purchased_tooling",
        "user_created_reusable_component",
        "fixture_family_template",
        "process_context_asset",
        "private_benchmark_reference",
        "public_engineering_knowledge"
      ]
    },
    "authority_level": {
      "$ref": "#/$defs/authority"
    },
    "supplier_or_author": {
      "type": [
        "string",
        "null"
      ]
    },
    "model_or_internal_number": {
      "type": [
        "string",
        "null"
      ]
    },
    "revision": {
      "$ref": "library_revision_v1.schema.json"
    },
    "units": {
      "enum": [
        "mm",
        "inch",
        "unitless"
      ]
    },
    "source_file": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "identity",
        "sha256",
        "source_classification",
        "licensing_usage_evidence"
      ],
      "properties": {
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_classification": {
          "enum": [
            "private_owner_authorized",
            "supplier_authorized_exact",
            "user_authored_exact"
          ]
        },
        "licensing_usage_evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_identity",
        "author_or_grantor",
        "usage_note"
      ],
      "properties": {
        "record_identity": {
          "type": "string",
          "minLength": 1
        },
        "author_or_grantor": {
          "type": "string",
          "minLength": 1
        },
        "usage_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "privacy_classification": {
      "enum": [
        "public",
        "synthetic_public",
        "private_local",
        "supplier_restricted",
        "organization_confidential"
      ]
    },
    "storage_policy": {
      "enum": [
        "embedded",
        "linked",
        "metadata_only",
        "not_applicable"
      ]
    },
    "edit_authority": {
      "enum": [
        "editable",
        "read_only",
        "editable_new_revision_only",
        "not_applicable"
      ]
    },
    "local_coordinate_system": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "owned_coordinate_frame_v1.schema.json"
        }
      ]
    },
    "preview_representation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "authority",
        "asset_identity",
        "visible_classification"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "parametric_preview",
            "exact_tessellation",
            "provisional_envelope",
            "metadata_card",
            "template_diagram"
          ]
        },
        "authority": {
          "enum": [
            "exact",
            "provisional",
            "informational",
            "none"
          ]
        },
        "asset_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "visible_classification": {
          "enum": [
            "exact_private",
            "exact_supplier_authorized",
            "exact_parametric",
            "provisional_not_exact",
            "metadata_only_not_geometry",
            "template_not_completed_fixture",
            "knowledge_not_geometry",
            "none"
          ]
        }
      }
    },
    "feature_definition": {
      "type": [
        "object",
        "null"
      ],
      "minProperties": 1
    },
    "mounting_interfaces": {
      "type": "array",
      "items": {
        "$ref": "mounting_interface_v1.schema.json"
      }
    },
    "functional_interfaces": {
      "type": "array",
      "items": {
        "$ref": "functional_interface_v1.schema.json"
      }
    },
    "contact_points": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "movement_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "state_id",
          "state_kind",
          "description"
        ],
        "properties": {
          "state_id": {
            "type": "string",
            "minLength": 1
          },
          "state_kind": {
            "enum": [
              "fixed",
              "open",
              "closed",
              "moving",
              "service"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_closed_states": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claimed",
        "open_state_id",
        "closed_state_id"
      ],
      "properties": {
        "claimed": {
          "type": "boolean"
        },
        "open_state_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "closed_state_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "keep_out_envelopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "maintenance_envelopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "material_manufacturing_intent": {
      "type": [
        "object",
        "null"
      ],
      "minProperties": 1
    },
    "bom_participation": {
      "$ref": "#/$defs/participation"
    },
    "advisory_bom_hint": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "classification",
        "description",
        "deliverable_eligible"
      ],
      "properties": {
        "classification": {
          "enum": [
            "unresolved_supplier_candidate",
            "generic_review_placeholder"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "deliverable_eligible": {
          "const": false
        }
      }
    },
    "export_participation": {
      "$ref": "#/$defs/output_participation"
    },
    "validation_participation": {
      "$ref": "#/$defs/validation_participation"
    },
    "configurable_variants": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "replacement_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replacement_class",
        "placement_compatible",
        "functionally_equivalent",
        "requires_interface_match",
        "requires_revalidation",
        "stale_evidence_after_replacement"
      ],
      "properties": {
        "replacement_class": {
          "type": [
            "string",
            "null"
          ]
        },
        "placement_compatible": {
          "type": "boolean"
        },
        "functionally_equivalent": {
          "type": "boolean"
        },
        "requires_interface_match": {
          "type": "boolean"
        },
        "requires_revalidation": {
          "type": "boolean"
        },
        "stale_evidence_after_replacement": {
          "type": "boolean"
        }
      }
    },
    "missing_link_behavior": {
      "enum": [
        "not_applicable",
        "block_geometry_dependent_actions",
        "retain_embedded_snapshot_and_mark_stale",
        "metadata_only_continue_with_warning"
      ]
    },
    "downstream_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "applicability": {
      "$ref": "#/$defs/string_array"
    },
    "limitations": {
      "$ref": "#/$defs/string_array"
    },
    "engineering_details": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "fxd_parametric_component"
          }
        }
      },
      "then": {
        "properties": {
          "category": {
            "const": "fxd_standard_parametric_primitive"
          },
          "units": {
            "enum": [
              "mm",
              "inch"
            ]
          },
          "edit_authority": {
            "enum": [
              "editable",
              "editable_new_revision_only"
            ]
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "parametric_preview"
              },
              "authority": {
                "const": "exact"
              },
              "visible_classification": {
                "const": "exact_parametric"
              }
            }
          },
          "feature_definition": {
            "type": "object",
            "minProperties": 1
          },
          "local_coordinate_system": {
            "type": "object"
          },
          "material_manufacturing_intent": {
            "type": "object",
            "minProperties": 1
          },
          "validation_participation": {
            "properties": {
              "exact_collision": {
                "const": "required"
              },
              "exact_clearance": {
                "const": "required"
              },
              "deterministic_validation": {
                "const": "required"
              },
              "manufacturing_release": {
                "const": "human confirmation required"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "exact_private_imported_cad"
          }
        }
      },
      "then": {
        "properties": {
          "source_file": {
            "type": "object",
            "properties": {
              "source_classification": {
                "const": "private_owner_authorized"
              }
            }
          },
          "privacy_classification": {
            "enum": [
              "private_local",
              "organization_confidential"
            ]
          },
          "storage_policy": {
            "enum": [
              "embedded",
              "linked"
            ]
          },
          "edit_authority": {
            "const": "read_only"
          },
          "units": {
            "enum": [
              "mm",
              "inch"
            ]
          },
          "local_coordinate_system": {
            "type": "object"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "exact_tessellation"
              },
              "authority": {
                "const": "exact"
              },
              "visible_classification": {
                "const": "exact_private"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "supplier_authorized_exact_cad"
          }
        }
      },
      "then": {
        "properties": {
          "supplier_or_author": {
            "type": "string",
            "minLength": 1
          },
          "model_or_internal_number": {
            "type": "string",
            "minLength": 1
          },
          "source_file": {
            "type": "object",
            "properties": {
              "source_classification": {
                "const": "supplier_authorized_exact"
              }
            }
          },
          "privacy_classification": {
            "const": "supplier_restricted"
          },
          "storage_policy": {
            "enum": [
              "embedded",
              "linked"
            ]
          },
          "edit_authority": {
            "const": "read_only"
          },
          "units": {
            "enum": [
              "mm",
              "inch"
            ]
          },
          "local_coordinate_system": {
            "type": "object"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "exact_tessellation"
              },
              "authority": {
                "const": "exact"
              },
              "visible_classification": {
                "const": "exact_supplier_authorized"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "metadata_only_commercial_component"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "private_purchased_tooling"
          },
          "storage_policy": {
            "const": "metadata_only"
          },
          "edit_authority": {
            "const": "read_only"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "metadata_card"
              },
              "authority": {
                "const": "informational"
              },
              "visible_classification": {
                "const": "metadata_only_not_geometry"
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output"
          },
          "validation_participation": {
            "properties": {
              "exact_collision": {
                "const": "excluded"
              },
              "exact_clearance": {
                "const": "excluded"
              },
              "manufacturing_release": {
                "const": "excluded"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "provisional_review_envelope"
          }
        }
      },
      "then": {
        "properties": {
          "source_file": {
            "type": "null"
          },
          "feature_definition": {
            "type": "null"
          },
          "mounting_interfaces": {
            "maxItems": 0
          },
          "functional_interfaces": {
            "maxItems": 0
          },
          "contact_points": {
            "maxItems": 0
          },
          "material_manufacturing_intent": {
            "type": "null"
          },
          "bom_participation": {
            "const": "excluded"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "provisional_envelope"
              },
              "authority": {
                "const": "provisional"
              },
              "visible_classification": {
                "const": "provisional_not_exact"
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output"
          },
          "validation_participation": {
            "properties": {
              "exact_collision": {
                "const": "excluded"
              },
              "exact_clearance": {
                "const": "excluded"
              },
              "manufacturing_release": {
                "const": "excluded"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "user_authored_reusable_component"
          }
        }
      },
      "then": {
        "properties": {
          "category": {
            "const": "user_created_reusable_component"
          },
          "supplier_or_author": {
            "type": "string",
            "minLength": 1
          },
          "local_coordinate_system": {
            "type": "object"
          },
          "mounting_interfaces": {
            "minItems": 1
          },
          "edit_authority": {
            "enum": [
              "editable",
              "editable_new_revision_only"
            ]
          }
        },
        "oneOf": [
          {
            "properties": {
              "feature_definition": {
                "type": "object",
                "minProperties": 1
              },
              "source_file": {
                "type": "null"
              }
            }
          },
          {
            "properties": {
              "source_file": {
                "type": "object",
                "properties": {
                  "source_classification": {
                    "const": "user_authored_exact"
                  }
                }
              },
              "feature_definition": {
                "type": "null"
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "fixture_family_template"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "fixture_family_template"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "template_diagram"
              },
              "authority": {
                "const": "informational"
              },
              "visible_classification": {
                "const": "template_not_completed_fixture"
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output",
            "properties": {
              "drawings": {
                "const": "excluded"
              }
            }
          },
          "engineering_details": {
            "required": [
              "configuration_parameters",
              "unsupported_conditions",
              "deterministic_validations_required",
              "required_human_review_questions"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "shop_standard"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "shop_standard_pack"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "enum": [
                  "none",
                  "metadata_card"
                ]
              },
              "authority": {
                "enum": [
                  "none",
                  "informational"
                ]
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output"
          },
          "engineering_details": {
            "required": [
              "scope",
              "precedence_level",
              "conflict_behavior"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "process_context_asset"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "process_context_asset"
          },
          "bom_participation": {
            "const": "excluded"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "enum": [
                  "none",
                  "metadata_card"
                ]
              },
              "authority": {
                "enum": [
                  "none",
                  "informational"
                ]
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "private_benchmark_reference"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "private_benchmark_reference"
          },
          "bom_participation": {
            "const": "excluded"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "enum": [
                  "none",
                  "metadata_card"
                ]
              },
              "authority": {
                "enum": [
                  "none",
                  "informational"
                ]
              }
            }
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output",
            "properties": {
              "drawings": {
                "const": "excluded"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_level": {
            "const": "public_engineering_knowledge"
          }
        }
      },
      "then": {
        "$ref": "#/$defs/no_item_geometry",
        "properties": {
          "category": {
            "const": "public_engineering_knowledge"
          },
          "units": {
            "const": "unitless"
          },
          "storage_policy": {
            "const": "not_applicable"
          },
          "edit_authority": {
            "const": "not_applicable"
          },
          "local_coordinate_system": {
            "type": "null"
          },
          "preview_representation": {
            "properties": {
              "kind": {
                "const": "none"
              },
              "authority": {
                "const": "none"
              },
              "visible_classification": {
                "const": "knowledge_not_geometry"
              }
            }
          },
          "feature_definition": {
            "type": "null"
          },
          "mounting_interfaces": {
            "maxItems": 0
          },
          "functional_interfaces": {
            "maxItems": 0
          },
          "bom_participation": {
            "const": "excluded"
          },
          "export_participation": {
            "$ref": "#/$defs/no_manufacturing_output"
          },
          "validation_participation": {
            "properties": {
              "broad_phase_collision": {
                "const": "excluded"
              },
              "exact_collision": {
                "const": "excluded"
              },
              "exact_clearance": {
                "const": "excluded"
              },
              "manufacturing_release": {
                "const": "excluded"
              },
              "ai_context": {
                "enum": [
                  "permitted",
                  "human confirmation required"
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "authority": {
      "enum": [
        "fxd_parametric_component",
        "exact_private_imported_cad",
        "supplier_authorized_exact_cad",
        "metadata_only_commercial_component",
        "provisional_review_envelope",
        "user_authored_reusable_component",
        "fixture_family_template",
