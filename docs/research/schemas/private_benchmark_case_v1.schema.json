{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fxd.invalid/research/private_benchmark_case_v1.schema.json",
  "title": "FXD private benchmark case v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "authority_level",
    "fixture_class",
    "product_material_forms",
    "manufacturing_process",
    "production_quantity",
    "source_part_construction",
    "build_orientation",
    "datum_hierarchy",
    "degrees_of_freedom",
    "supports",
    "locators",
    "stops",
    "clamps",
    "force_reaction_mappings",
    "base_structural_strategy",
    "loading_sequence",
    "clamping_sequence",
    "process_sequence",
    "unloading_sequence",
    "access_review",
    "process_context_asset_ids",
    "manufacturability",
    "wear_replaceable_components",
    "successful_principles",
    "compromises",
    "failure_modes",
    "improvements_fxd_should_propose",
    "human_acceptance_criteria",
    "human_disposition",
    "authorship",
    "provenance",
    "privacy_classification",
    "selected_public_release_permission",
    "linked_private_asset_identities"
  ],
  "properties": {
    "schema_version": {
      "const": "fxd-private-benchmark-case-v1"
    },
    "case_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "authority_level": {
      "const": "private_benchmark_reference"
    },
    "fixture_class": {
      "type": "string",
      "minLength": 1
    },
    "product_material_forms": {
      "$ref": "#/$defs/string_array"
    },
    "manufacturing_process": {
      "$ref": "#/$defs/string_array"
    },
    "production_quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "period",
        "confidence"
      ],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1
        },
        "period": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "synthetic",
            "estimated",
            "recorded"
          ]
        }
      }
    },
    "source_part_construction": {
      "$ref": "#/$defs/string_array"
    },
    "build_orientation": {
      "type": "string",
      "minLength": 1
    },
    "datum_hierarchy": {
      "$ref": "#/$defs/string_array"
    },
    "degrees_of_freedom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constrained",
        "intentionally_floating"
      ],
      "properties": {
        "constrained": {
          "$ref": "#/$defs/string_array"
        },
        "intentionally_floating": {
          "$ref": "#/$defs/string_array_allow_empty"
        }
      }
    },
    "supports": {
      "$ref": "#/$defs/string_array"
    },
    "locators": {
      "$ref": "#/$defs/string_array"
    },
    "stops": {
      "$ref": "#/$defs/string_array"
    },
    "clamps": {
      "$ref": "#/$defs/string_array"
    },
    "force_reaction_mappings": {
      "$ref": "#/$defs/string_array"
    },
    "base_structural_strategy": {
      "$ref": "#/$defs/string_array"
    },
    "loading_sequence": {
      "$ref": "#/$defs/string_array"
    },
    "clamping_sequence": {
      "$ref": "#/$defs/string_array"
    },
    "process_sequence": {
      "$ref": "#/$defs/string_array"
    },
    "unloading_sequence": {
      "$ref": "#/$defs/string_array"
    },
    "access_review": {
      "$ref": "#/$defs/string_array"
    },
    "process_context_asset_ids": {
      "$ref": "#/$defs/string_array_allow_empty"
    },
    "manufacturability": {
      "$ref": "#/$defs/string_array"
    },
    "wear_replaceable_components": {
      "$ref": "#/$defs/string_array_allow_empty"
    },
    "successful_principles": {
      "$ref": "#/$defs/string_array"
    },
    "compromises": {
      "$ref": "#/$defs/string_array"
    },
    "failure_modes": {
      "$ref": "#/$defs/string_array"
    },
    "improvements_fxd_should_propose": {
      "$ref": "#/$defs/string_array"
    },
    "human_acceptance_criteria": {
      "$ref": "#/$defs/string_array"
    },
    "human_disposition": {
      "enum": [
        "accepted_reference",
        "accepted_with_conditions",
        "rejected_reference",
        "not_yet_reviewed",
        "synthetic_example_only"
      ]
    },
    "authorship": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "string",
      "minLength": 1
    },
    "privacy_classification": {
      "enum": [
        "private_local_only",
        "synthetic_public",
        "selected_public_release"
      ]
    },
    "selected_public_release_permission": {
      "type": "boolean"
    },
    "linked_private_asset_identities": {
      "$ref": "#/$defs/string_array_allow_empty"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "string_array_allow_empty": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
